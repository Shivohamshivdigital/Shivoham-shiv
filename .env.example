# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Brevo lead form (used by /api/contact serverless function) ---
# BREVO_API_KEY: Required. Create at Brevo → Settings → SMTP & API → API Keys.
BREVO_API_KEY="xkeysib-xxxxxxxx"

# LEAD_NOTIFY_EMAIL: Where new lead notifications are emailed (optional).
LEAD_NOTIFY_EMAIL="shivohamshivdigital@gmail.com"

# BREVO_SENDER_EMAIL: A verified sender address in your Brevo account (optional).
BREVO_SENDER_EMAIL="shivohamshivdigital@gmail.com"

# BREVO_LIST_ID: Numeric Brevo contact list id to add leads to (optional).
BREVO_LIST_ID=""

# --- Razorpay payments (used by /api/razorpay/* serverless functions) ---
# Create keys at Razorpay Dashboard → Settings → API Keys.
# Use rzp_test_... keys while testing, rzp_live_... when going live.
RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"

# --- Admin panel + database (Firebase Firestore) for /admin page ---
# From Firebase Console → Project Settings → Service accounts → Generate new private key.
# The downloaded JSON contains all three values below.
FIREBASE_PROJECT_ID="shivoham-shiv"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxx@shivoham-shiv.iam.gserviceaccount.com"
# Paste the full private key. Keep the \n sequences exactly as they appear in the JSON.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# Password to log into the /admin dashboard.
ADMIN_PASSWORD="choose_a_strong_password"
# Secret API key for the programmatic export endpoint (/api/admin/export).
# Use a long random string. Send it as the x-api-key header or ?key= query param.
ADMIN_API_KEY="choose_a_long_random_api_key"

# --- LinkedIn AI-news agent (/api/linkedin/*) ---
# The agent scrapes AI-lab blogs, writes a <200-word post with Gemini, saves it
# as a DRAFT, then posts to your company page when you approve it in /admin.
# See docs/LINKEDIN_AGENT.md for the full token + page-id setup walkthrough.
#
# OAuth access token with the w_organization_social scope (from your LinkedIn
# developer app). Required only for the "Publish" button.
LINKEDIN_ACCESS_TOKEN=""
# Your company page id. Get it from the page URL or LinkedIn's org API.
# Accepts the full URN or a bare number, e.g. urn:li:organization:12345678
LINKEDIN_ORG_URN=""
# LinkedIn-Version header (YYYYMM). Bump if LinkedIn deprecates this version.
LINKEDIN_API_VERSION="202506"
# Vercel injects this as an Authorization: Bearer token on scheduled cron runs.
# Set the SAME value in Vercel → Settings → Environment Variables.
CRON_SECRET="choose_a_long_random_cron_secret"
# Optional: override the Gemini model used to write posts (default gemini-2.0-flash).
GEMINI_MODEL="gemini-2.0-flash"
# Optional: comma-separated RSS feeds to scrape (overrides the built-in AI-lab feeds).
LINKEDIN_FEEDS=""
# Optional: the voice/brand the post should be written in.
LINKEDIN_BRAND=""
