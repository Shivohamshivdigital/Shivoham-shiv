# Copy this file to ".env" for LOCAL use (npm run draft).
# For GitHub Actions, add the same names as repository SECRETS instead.

# --- AI model that writes the post (at least ONE required) ---
# Claude is primary, Gemini is fallback. Claude key: https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional: nudge the writing style.
AGENT_BRAND_VOICE=Confident, insightful, founder-to-founder. No hype cliches.

# --- LinkedIn publishing (official API, needs w_member_social scope) ---
# See README.md "STEP 2" for how to get the token.
LINKEDIN_ACCESS_TOKEN=
# Optional. If blank, resolved automatically from the token.
LINKEDIN_AUTHOR_URN=

# Optional: override the AI-news feeds (comma-separated RSS URLs).
# AGENT_FEEDS=https://openai.com/news/rss.xml,https://www.anthropic.com/news/rss.xml
