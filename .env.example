# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Brevo lead form (used by /api/contact serverless function) ---
# BREVO_API_KEY: Required. Create at Brevo → Settings → SMTP & API → API Keys.
BREVO_API_KEY="xkeysib-xxxxxxxx"

# LEAD_NOTIFY_EMAIL: Where new lead notifications are emailed (optional).
LEAD_NOTIFY_EMAIL="shivohamshivdigital@gmail.com"

# BREVO_SENDER_EMAIL: A verified sender address in your Brevo account (optional).
BREVO_SENDER_EMAIL="shivohamshivdigital@gmail.com"

# BREVO_LIST_ID: Numeric Brevo contact list id to add leads to (optional).
BREVO_LIST_ID=""

# --- Razorpay payments (used by /api/razorpay/* serverless functions) ---
# Create keys at Razorpay Dashboard → Settings → API Keys.
# Use rzp_test_... keys while testing, rzp_live_... when going live.
RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"

# --- Admin panel + database (Firebase Firestore) for /admin page ---
# From Firebase Console → Project Settings → Service accounts → Generate new private key.
# The downloaded JSON contains all three values below.
FIREBASE_PROJECT_ID="shivoham-shiv"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxx@shivoham-shiv.iam.gserviceaccount.com"
# Paste the full private key. Keep the \n sequences exactly as they appear in the JSON.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# Password to log into the /admin dashboard.
ADMIN_PASSWORD="choose_a_strong_password"
# Secret API key for the programmatic export endpoint (/api/admin/export).
# Use a long random string. Send it as the x-api-key header or ?key= query param.
ADMIN_API_KEY="choose_a_long_random_api_key"

# ============================================================================
# LinkedIn AI Agent (/api/agent/*) — see SETUP-LINKEDIN-AGENT.md
# Daily cron scrapes AI news, writes a <200-word post, emails you an approve
# link, and publishes to LinkedIn on approval.
# ============================================================================

# Protects /api/agent/run. Vercel Cron auto-sends this as a Bearer token.
# Generate a long random string. For manual runs: /api/agent/run?key=THIS
CRON_SECRET="choose_a_long_random_secret"

# --- AI models that write the post (at least ONE is required) ---
# Claude is primary (best quality); Gemini is the fallback. Get a Claude key at
# https://console.anthropic.com → API Keys.
ANTHROPIC_API_KEY="sk-ant-xxxxxxxx"
ANTHROPIC_MODEL="claude-sonnet-4-6"
# GEMINI_API_KEY is already defined above; GEMINI_MODEL is optional.
GEMINI_MODEL="gemini-2.5-flash"

# Optional: nudge the writing style/voice of the posts.
AGENT_BRAND_VOICE="Confident, insightful, founder-to-founder. No hype clichés."

# --- LinkedIn publishing (official API; needs w_member_social scope) ---
# How to get these: SETUP-LINKEDIN-AGENT.md
LINKEDIN_ACCESS_TOKEN="your_linkedin_oauth_access_token"
# Optional. If omitted, resolved from the token via /v2/userinfo (needs openid+profile).
LINKEDIN_AUTHOR_URN="urn:li:person:xxxxxxxx"

# Where approval emails are sent (defaults to LEAD_NOTIFY_EMAIL, then owner).
AGENT_NOTIFY_EMAIL="shivohamshivdigital@gmail.com"

# Optional: override the default AI-news feed list (comma-separated RSS URLs).
# AGENT_FEEDS="https://openai.com/news/rss.xml,https://www.anthropic.com/news/rss.xml"
