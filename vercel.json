{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/blog/:slug", "destination": "/api/post?slug=:slug" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
