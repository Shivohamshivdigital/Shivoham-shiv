# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Brevo lead form (used by /api/contact serverless function) ---
# BREVO_API_KEY: Required. Create at Brevo → Settings → SMTP & API → API Keys.
BREVO_API_KEY="xkeysib-xxxxxxxx"

# LEAD_NOTIFY_EMAIL: Where new lead notifications are emailed (optional).
LEAD_NOTIFY_EMAIL="info@shivohamshiv.com"

# BREVO_SENDER_EMAIL: A verified sender address in your Brevo account (optional).
BREVO_SENDER_EMAIL="info@shivohamshiv.com"

# BREVO_LIST_ID: Numeric Brevo contact list id to add leads to (optional).
BREVO_LIST_ID=""
